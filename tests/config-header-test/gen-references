#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(dirname $(readlink -f $0))"
OUTDIR="$SCRIPT_DIR/config-artifacts-ref"
PLATFORM="*"
JOBS=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4)

usage() {
	echo "Usage: $0 [-o|--outdir dir] [-j|--jobs N] [platform]"
	echo ""
	echo "  -o|--outdir   Output directory for the conf.h/conf.mk files"
	echo "                (default: $OUTDIR)"
	echo "  -j|--jobs     Number of parallel jobs (default: $JOBS)"
	echo "  platform      Bash glob; all platforms are processed if omitted"
}

# Manual parser for short and long options
while [[ $# -gt 0 ]]; do
	case $1 in
	-h | --help)
		usage
		exit 0
		;;
	-o | --outdir)
		OUTDIR="$2"
		shift 2
		;;
	-j | --jobs)
		JOBS="$2"
		shift 2
		;;
	-j*)
		JOBS="${1#-j}"
		shift
		;;
	-*)
		echo "Unknown option: $1"
		usage
		exit 1
		;;
	*) # First non-option argument is the start of the command
		break
		;;
	esac
done

if [ -n "$1" ]; then
	PLATFORM="$1"
fi

# Collect all (platform, arch) pairs that match the glob
declare -a plats=()
declare -a arches=()

for list in "$SCRIPT_DIR"/platform-list.*; do
	arch="${list##*.}"
	while IFS= read -r platform; do
		if [[ "$platform" == $PLATFORM ]]; then
			plats+=("$platform")
			arches+=("$arch")
		fi
	done <"$list"
done

total=${#plats[@]}
if (( total == 0 )); then
	echo "No platforms matched '$PLATFORM'" >&2
	exit 1
fi

echo "Processing $total platform(s) with -j${JOBS}..."

# --- Parallel execution: process in batches of JOBS ---
failures=0
i=0
while (( i < total )); do
	# Launch a batch of up to JOBS jobs
	batch_end=$(( i + JOBS < total ? i + JOBS : total ))
	declare -a batch_pids=()

	for (( j=i; j<batch_end; j++ )); do
		"$SCRIPT_DIR/gen-config-header" \
			"$OUTDIR" "${plats[$j]}" "${arches[$j]}" &
		batch_pids+=($!)
	done

	# Collect results for this batch
	for (( j=0; j<${#batch_pids[@]}; j++ )); do
		k=$(( i + j ))
		if wait "${batch_pids[$j]}"; then
			echo "Done: ${plats[$k]}"
		else
			echo "FAILED: ${plats[$k]}" >&2
			failures=$(( failures + 1 ))
		fi
	done

	i=$batch_end
done

if (( failures > 0 )); then
	echo "=== $failures platform(s) failed ===" >&2
	exit 1
fi

echo "=== Done (${total} platforms) ==="
