menu "Pseudo TAs"

config ATTESTATION_PTA
	bool "Attestation pseudo TA"
	default n
	depends on REE_FS || RPMB_FS
	help
	  Enable the pseudo TA that provides an interface to request
	  measurements of a TA or the TEE binary.  Requires at least one
	  secure storage back-end (REE FS or RPMB FS).

config ATTESTATION_PTA_KEY_SIZE
	int "Attestation PTA RSA key size (bits)"
	default 3072
	range 528 4096
	depends on ATTESTATION_PTA
	help
	  Size in bits of the RSA key pair generated by the attestation
	  pseudo TA.  Must be at least 528 given the PSS padding formula:
	  emLen >= hlen + sLen + 2 = 32 + 32 + 2 = 66 bytes, where
	  emLen = ceil((modBits - 1) / 8).
	  See https://tools.ietf.org/html/rfc8017#section-8.1.1 and
	  https://tools.ietf.org/html/rfc8017#section-9.1.1

endmenu # Pseudo TAs
